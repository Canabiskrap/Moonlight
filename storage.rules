rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      // Allow everyone to read product images and files
      allow read: if true;
      
      // Allow specific admin emails to upload and delete
      allow write: if request.auth != null && 
        (request.auth.token.email.lower() in ["canabiskrap07@gmail.com", "esraa0badr@gmail.com"]);
    }

    match /test/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
