rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /products/{allPaths=**} {
      // Allow everyone to read product images and files
      allow read: if true;
      
      // Allow specific admin emails to upload and delete
      // We check for authentication and email match
      allow write: if request.auth != null && 
        (request.auth.token.email == "canabiskrap07@gmail.com" || 
         request.auth.token.email == "Esraa0badr@gmail.com");
    }
  }
}
