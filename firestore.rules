rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if user is admin
    function isAdmin() {
      return isAuthenticated() && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        request.auth.token.email.matches("(?i)canabiskrap07@gmail.com") ||
        request.auth.token.email.matches("(?i)esraa0badr@gmail.com") ||
        request.auth.token.email.matches("(?i)karmabiskrap@gmail.com") ||
        request.auth.token.email.matches("(?i)canabiskrap007@gmail.com") ||
        request.auth.token.email.matches("(?i)samemlywk@gmail.com")
      );
    }

    // Products: Anyone can read basic info, only admin can read sensitive info
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Prevent reading downloadUrl for non-admins
      // Note: Firestore rules don't support field-level security on read, 
      // so we rely on encryption for the downloadUrl field.
    }

    // Services: Anyone can read basic info, only admin can read sensitive info
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Orders: Admin can read/write all, users can only read/write their own
    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource.data.userId == request.auth.uid || resource.data.customerEmail == request.auth.token.email));
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin();
    }

    // Users: Users can read/write their own profile, admin can read all
    match /users/{userId} {
      allow read, write: if isAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    // Settings: Anyone can read, only admin can write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Inspiration Notes: Only admins can read/write
    match /inspiration_notes/{noteId} {
      allow read, write: if isAdmin();
    }

    // Creative Gallery: Only admins can read/write
    match /creative_gallery/{itemId} {
      allow read, write: if isAdmin();
    }
    
    // Default deny
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
